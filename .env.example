# 이 파일을 .env로 복사한 뒤 값을 채워 사용하세요.
# .env 파일은 .gitignore에 등록되어 있어 커밋되지 않습니다.

# === 필수 — Claude API ===
# https://console.anthropic.com → Billing에 $5+ 충전 → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# === 인스타 자동 업로드 시 필요 ===
# 모두 https://developers.facebook.com → 본인 앱 → Instagram → API setup 에서 받음

# Instagram Business Account ID (17841...로 시작하는 16-17자리 숫자)
INSTAGRAM_USER_ID=17841...

# Instagram 장기 액세스 토큰 (60일 유효, 만료 전 갱신 필요)
# Meta 콘솔의 'Generate access tokens' 버튼이 이미 장기 토큰을 발급함
INSTAGRAM_ACCESS_TOKEN=IGAA...

# Instagram App Secret (FB App Secret과 다른 별도 값)
# 토큰 갱신/교환에만 사용. exchange_token.py 가 이걸 필요로 함
INSTAGRAM_APP_SECRET=...

# === 이미지 호스팅 (둘 중 하나) ===

# 옵션 A — Cloudinary (권장, 안정적, 무료 25GB)
# https://cloudinary.com → Settings → Upload → Unsigned preset 생성
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_UPLOAD_PRESET=...

# 옵션 B — Imgur (최근 API 등록 어려움, 비추천)
# https://imgur.com/account/settings/apps
# IMGUR_CLIENT_ID=...

# === 배경 이미지 검색 (선택, 강력 추천) ===
# Unsplash API — 뉴스 컨셉에 맞는 사진을 검색해서 배경으로 사용 (헤비 블러 + 다크 오버레이).
# 미설정 시 procedural 보케 배경으로 자동 폴백.
# https://unsplash.com/developers → New Application → Access Key 복사
UNSPLASH_ACCESS_KEY=...

# === 채널 선택 (선택) ===
# main.py가 사용할 채널 ID. 미설정 시 daily_enter_kr (기본).
# 후보: daily_enter_kr | daily_sports_kr | daily_economy_kr
# CHANNEL=daily_enter_kr

# === Discord 알림 (선택) ===
# 워크플로우 실패 시 알림. 미설정 시 GH 이메일로만 통보.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# === (선택) Facebook 앱 — 일부 디버깅용 ===
# 현재 파이프라인은 사용 안 함. 다른 Graph API 호출 시 참고
# APP_ID=...
# APP_SECRET=...

# === 쿠팡 파트너스 (선택) ===
# https://partners.coupang.com 가입 후 마이페이지에서 확인 가능한 트래킹 ID
# 미설정 시: 랜딩 페이지는 일반 검색 URL (수익 X)
COUPANG_AF_ID=
