# 이 파일을 .env로 복사한 뒤 값을 채워 사용하세요.
# .env 파일은 .gitignore에 등록되어 있어 커밋되지 않습니다.

# === 필수 ===
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# === 선택 (인스타 자동 업로드 시) ===
# 셋 모두 채워야 업로드가 작동합니다. 하나라도 비면 이미지 생성까지만 실행됩니다.

# Instagram Business Account ID (숫자)
INSTAGRAM_USER_ID=17841...

# Instagram 장기 액세스 토큰 (60일 유효, 만료 전 갱신 필요)
INSTAGRAM_ACCESS_TOKEN=EAAB...

# https://api.imgur.com/oauth2/addclient 에서 발급 (Anonymous usage)
IMGUR_CLIENT_ID=abc123...
